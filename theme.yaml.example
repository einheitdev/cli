# Example theme for einheit-cli — "psychotropic" palette.
#
# Copy to ~/.einheit/theme.yaml. Values accept either FTXUI enum
# names (GreenLight, Yellow, CyanLight, …) or #RRGGBB hex literals.
# Unset keys keep their built-in defaults.

# Semantic colours
good:     "#99DA3D"     # lime — healthy, committed, active, +added
warn:     "#F9CB52"     # khaki — caution, ~changed
bad:      "#FF5454"     # red — failed, denied, -removed
dim:      "#626262"     # grey39 — muted context
emphasis: "#F6FAFA"     # near-white — headers, important values
info:     "#4DB9F4"     # electric blue — labels, neutral highlights

# Chrome
border:      "#4E4E4E"  # grey30 — header rule, column separators
accent:      "#E061F9"  # violet — logo + prompt glyph

# Prompt — user @ host rendered with three distinct colours
prompt_user: "#ADADF3"  # lavender — the `user` part
prompt_at:   "#808080"  # grey50 — the `@` separator
prompt_host: "#7FD3A5"  # turquoise — the host part
