# Doxygen config for einheit-cli public API documentation.
# Run: doxygen Doxyfile
# Output: build/doc/html/index.html

PROJECT_NAME           = "einheit-cli"
PROJECT_NUMBER         = 0.0.1
PROJECT_BRIEF          = "Einheit Networks shared CLI framework"
OUTPUT_DIRECTORY       = build/doc
CREATE_SUBDIRS         = NO
ALLOW_UNICODE_NAMES    = YES
OUTPUT_LANGUAGE        = English

BRIEF_MEMBER_DESC      = YES
REPEAT_BRIEF           = YES
ALWAYS_DETAILED_SEC    = NO
INLINE_INHERITED_MEMB  = YES
FULL_PATH_NAMES        = YES
JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = YES
TAB_SIZE               = 2
OPTIMIZE_OUTPUT_FOR_C  = NO
BUILTIN_STL_SUPPORT    = YES
CPP_CLI_SUPPORT        = NO
EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
HIDE_FRIEND_COMPOUNDS  = NO
HIDE_IN_BODY_DOCS      = NO
SHOW_INCLUDE_FILES     = YES
SHOW_USED_FILES        = YES
SHOW_FILES             = YES
SHOW_NAMESPACES        = YES
SORT_MEMBER_DOCS       = YES
SORT_BRIEF_DOCS        = YES

INPUT                  = include src adapters
RECURSIVE              = YES
EXCLUDE_PATTERNS       = */build/* */build-debug/* */build-aarch64/*
FILE_PATTERNS          = *.h *.cc

GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html
HTML_COLORSTYLE        = AUTO_LIGHT
GENERATE_LATEX         = NO
GENERATE_XML           = NO

USE_MDFILE_AS_MAINPAGE = README.md

QUIET                  = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO

SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES
VERBATIM_HEADERS       = YES
